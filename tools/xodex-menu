#!/usr/bin/env bash
# Xodex interactive console menu
set -euo pipefail

XODEX_HOME="${XODEX_HOME:-/usr/local/xodex}"
PROGRESS="${HOME}/.xodex/progress.json"

mkdir -p "${HOME}/.xodex"
if [ ! -f "${PROGRESS}" ]; then
  cat > "${PROGRESS}" <<'EOF'
{
  "username": "xodex",
  "language": "ru",
  "bookmarks": {},
  "lessons_completed": [],
  "settings": { "theme": "dark", "last_opened": null }
}
EOF
fi

lang_hint() {
  local lang
  lang=$(python3 - <<'PY' 2>/dev/null || echo ru
import json, os
p = os.path.expanduser("~/.xodex/progress.json")
try:
    print(json.load(open(p)).get("language", "ru"))
except Exception:
    print("ru")
PY
)
  echo "${lang}"
}

open_path() {
  local path="$1"
  if [ ! -e "${path}" ]; then
    echo "Not found: ${path}"
    return 1
  fi
  if [ -d "${path}" ]; then
    ls -la "${path}"
    echo
    echo "cd \"${path}\""
    return 0
  fi
  ${PAGER:-less} "${path}"
}

banner() {
  cat <<'EOF'
 __  __          _
 \ \/ /___   __| | _____  __
  \  // _ \ / _` |/ _ \ \/ /
  /  \ (_) | (_| |  __/>  <
 /_/\_\___/ \__,_|\___/_/\_\

  Educational Debian Live — terminal first
EOF
}

main_menu() {
  local lang
  lang=$(lang_hint)
  clear 2>/dev/null || true
  banner
  echo "  HOME=${XODEX_HOME}   lang=${lang}"
  echo
  echo "  1) Docs (lessons 0–10)"
  echo "  2) Examples"
  echo "  3) Courses / labs"
  echo "  4) Quick start: Hello C"
  echo "  5) Quick start: Hello Python"
  echo "  6) Toggle language (ru/en in progress.json)"
  echo "  7) Toggle theme (dark/light prompt)"
  echo "  8) Shell (exit menu)"
  echo "  0) Quit"
  echo
  read -r -p "Choice: " choice
  case "${choice}" in
    1)
      open_path "${XODEX_HOME}/docs"
      read -r -p "Enter to continue..." _
      ;;
    2)
      open_path "${XODEX_HOME}/examples"
      read -r -p "Enter to continue..." _
      ;;
    3)
      open_path "${XODEX_HOME}/courses"
      read -r -p "Enter to continue..." _
      ;;
    4)
      local f="${XODEX_HOME}/examples/c/hello/hello.c"
      if [ -f "${f}" ]; then
        echo "=== ${f} ==="
        cat "${f}"
        echo
        echo "Compile: gcc -o /tmp/hello ${f} && /tmp/hello"
        gcc -o /tmp/xodex-hello "${f}" && /tmp/xodex-hello || true
      else
        echo "Example missing: ${f}"
      fi
      read -r -p "Enter to continue..." _
      ;;
    5)
      local f="${XODEX_HOME}/examples/python/hello/hello.py"
      if [ -f "${f}" ]; then
        python3 "${f}"
      else
        echo "Example missing: ${f}"
      fi
      read -r -p "Enter to continue..." _
      ;;
    6)
      python3 - <<'PY'
import json, os
p = os.path.expanduser("~/.xodex/progress.json")
data = json.load(open(p)) if os.path.exists(p) else {}
cur = data.get("language", "ru")
data["language"] = "en" if cur == "ru" else "ru"
os.makedirs(os.path.dirname(p), exist_ok=True)
json.dump(data, open(p, "w"), indent=2, ensure_ascii=False)
print("language ->", data["language"])
PY
      read -r -p "Enter to continue..." _
      ;;
    7)
      if [ "${XODEX_THEME:-dark}" = "dark" ]; then
        export XODEX_THEME=light
      else
        export XODEX_THEME=dark
      fi
      python3 - <<PY
import json, os
p = os.path.expanduser("~/.xodex/progress.json")
data = json.load(open(p)) if os.path.exists(p) else {}
data.setdefault("settings", {})["theme"] = os.environ.get("XODEX_THEME", "dark")
json.dump(data, open(p, "w"), indent=2, ensure_ascii=False)
print("theme ->", data["settings"]["theme"])
PY
      read -r -p "Enter to continue..." _
      ;;
    8)
      echo "Starting shell. Type 'xodex-menu' to return."
      exec "${SHELL:-/bin/bash}" -l
      ;;
    0)
      exit 0
      ;;
    *)
      echo "Unknown choice"
      sleep 1
      ;;
  esac
}

while true; do
  main_menu
done
