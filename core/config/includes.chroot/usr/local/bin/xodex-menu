#!/usr/bin/env bash
# Главное меню Xodex — whiptail TUI с навигацией стрелками

XODEX_HOME="${XODEX_HOME:-/usr/local/xodex}"
PAGER="${PAGER:-less}"

open_path() {
  local path="$1"
  if [ ! -e "${path}" ]; then
    whiptail --title "Ошибка" --msgbox "Не найдено: ${path}" 8 50
    return 1
  fi
  if [ -d "${path}" ]; then
    ls -la "${path}" | ${PAGER}
  else
    ${PAGER} "${path}"
  fi
}

while true; do
  DATE=$(date +"%H:%M")
  MEM=$(free -m | awk '/^Mem:/{print $3"МБ/"$2"МБ"}')

  CHOICE=$(whiptail --title "XODEX OC  |  $(whoami)@xodex  |  ${DATE}" \
    --menu "Память: ${MEM}" 0 0 8 \
    "1" "Просмотр документации (xodex-docs)" \
    "2" "Примеры" \
    "3" "Курсы / лабораторные" \
    "4" "Быстрый старт: Hello C" \
    "5" "Быстрый старт: Hello Python" \
    "6" "Монитор системы (btop)" \
    "7" "Оболочка (выйти в bash)" \
    "8" "Выключение" \
    3>&1 1>&2 2>&3) || true

  case "${CHOICE}" in
    1)
      xodex-docs
      echo -n "Нажмите Enter для продолжения..."; read -r _
      ;;
    2)
      open_path "${XODEX_HOME}/examples"
      ;;
    3)
      open_path "${XODEX_HOME}/courses"
      ;;
    4)
      f="${XODEX_HOME}/examples/c/hello/hello.c"
      if [ -f "${f}" ]; then
        whiptail --title "Hello C" --textbox "${f}" 20 70
        gcc -o /tmp/xodex-hello "${f}" 2>/dev/null && /tmp/xodex-hello || true
        echo -n "Нажмите Enter для продолжения..."; read -r _
      else
        whiptail --title "Ошибка" --msgbox "Не найдено: ${f}" 8 60
      fi
      ;;
    5)
      f="${XODEX_HOME}/examples/python/hello/hello.py"
      if [ -f "${f}" ]; then
        python3 "${f}"
        echo -n "Нажмите Enter для продолжения..."; read -r _
      else
        whiptail --title "Ошибка" --msgbox "Не найдено: ${f}" 8 60
      fi
      ;;
    6)
      btop || htop || top
      ;;
    7)
      whiptail --title "Оболочка" --msgbox "Введите 'exit' для возврата в меню." 8 50
      bash -l
      ;;
    8)
      if whiptail --title "Выключение" --yesno "Выключить XODEX?" 8 40; then
        sudo poweroff
      fi
      ;;
  esac
done
